{
  "name": "miclaw-app",
  "version": "0.12.4",
  "description": "Maintain your lobsters",
  "bin": {
    "miclaw": "./bin/miclaw.mjs"
  },
  "files": [
    "bin/",
    "helpers/",
    "scripts/",
    ".next/standalone/",
    ".next/static/",
    "public/"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "./scripts/build.sh",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=verbose",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "postinstall": "./scripts/postinstall.sh",
    "check": "bun run lint && bun run typecheck && bun run test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "config",
    "visualizer",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NGabry/MiClaw.git"
  },
  "license": "MIT",
  "dependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "d3-hierarchy": "^3.1.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
